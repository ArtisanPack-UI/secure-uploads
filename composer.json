{
  "name": "artisanpack-ui/secure-uploads",
  "description": "File upload security for Laravel — content-type validation, filename sanitization, malware scanning (ClamAV / VirusTotal), rate limiting, secure storage, and quarantine.",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": [
    "laravel",
    "security",
    "uploads",
    "files",
    "validation",
    "malware",
    "antivirus",
    "clamav",
    "virustotal"
  ],
  "autoload": {
    "psr-4": {
      "ArtisanPackUI\\SecureUploads\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Jacob Martella",
      "email": "support@artisanpackui.dev"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "artisanpack-ui/core": "^1.0",
    "symfony/mime": "^6.0|^7.0"
  },
  "require-dev": {
    "artisanpack-ui/code-style": "^1.1",
    "artisanpack-ui/code-style-pint": "^1.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.75",
    "laravel/pint": "^1.26",
    "orchestra/testbench": "^10.2",
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin-laravel": "^3.2"
  },
  "scripts": {
    "lint": [
      "./vendor/bin/php-cs-fixer fix --dry-run --diff",
      "./vendor/bin/phpcs"
    ],
    "fix": "./vendor/bin/php-cs-fixer fix",
    "cs": "./vendor/bin/phpcs",
    "cs:fix": "./vendor/bin/phpcbf",
    "test": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.2"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ArtisanPackUI\\SecureUploads\\SecureUploadsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
